# -----------------------------------------------------------------------------
# DOMÍNIOS
# -----------------------------------------------------------------------------

TRAEFIK_DOMAIN=traefik.SEU_DOMINIO_AQUI
CHATWOOT_DOMAIN=chat.SEU_DOMINIO_AQUI
ESPOCRM_DOMAIN=crm.SEU_DOMINIO_AQUI

 =============================================================================
# TRAEFIK - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie para traefik/.env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais!
# =============================================================================

# -----------------------------------------------------------------------------
# DASHBOARD - Autenticação Basic Auth
# Gerar o hash com:
#   htpasswd -nb admin SUA_SENHA | sed -e 's/\$/\$\$/g'
# -----------------------------------------------------------------------------

TRAEFIK_DASHBOARD_USER=admin:GERE_COM_htpasswd


# =============================================================================
# CHATWOOT - VARIÁVEIS DE AMBIENTE
# =============================================================================
# ATENÇÃO: Este arquivo NÃO deve ser commitado no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
SECRET_KEY_BASE=GERE_COM_openssl_rand_-hex_64
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker


# -----------------------------------------------------------------------------
# BANCO DE DADOS - PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=chatwoot-postgres
POSTGRES_PORT=5432
# POSTGRES_DB=chatwoot_production
# POSTGRES_USER=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_DATABASE=chatwoot_production
POSTGRES_PASSWORD=SENHA_FORTE_POSTGRES_AQUI_GERE_COM_openssl rand -base64 32

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_URL=redis://:SENHA_FORTE_REDIS_AQUI@chatwoot-redis:6379/0
REDIS_PASSWORD=SENHA_FORTE_REDIS_AQUI_GERE_COM_openssl rand -hex 32

# -----------------------------------------------------------------------------
# ARMAZENAMENTO DE ARQUIVOS (S3 - opcional, padrão local)
# -----------------------------------------------------------------------------
ACTIVE_STORAGE_SERVICE=local
# Para S3:
# ACTIVE_STORAGE_SERVICE=amazon
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# EMAIL / SMTP
# -----------------------------------------------------------------------------
MAILER_SENDER_EMAIL=noreply@seudominio.com
SMTP_DOMAIN=seudominio.com
SMTP_ADDRESS=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=SEU_MAILTRAP_USERNAME
SMTP_PASSWORD=SEU_MAILTRAP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=pt_BR
ENABLE_ACCOUNT_SIGNUP=false
LOG_LEVEL=info
LOG_SIZE=500

# -----------------------------------------------------------------------------
# 2FA (Two-Factor Authentication)
# -----------------------------------------------------------------------------
# Habilitado por padrão nas configurações de conta do Chatwoot
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=GERE_COM_openssl rand -hex 32
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=GERE_COM_openssl rand -hex 32
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=GERE_COM_openssl rand -hex 32

# =============================================================================
# ESPOCRM - VARIÁVEIS DE AMBIENTE
# =============================================================================
# ATENÇÃO: Este arquivo NÃO deve ser commitado no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS - MariaDB
# -----------------------------------------------------------------------------
ESPOCRM_DATABASE_HOST=espocrm-mariadb
ESPOCRM_DATABASE_PORT=3306
ESPOCRM_DATABASE_NAME=espocrm
ESPOCRM_DATABASE_USER=espocrm
ESPOCRM_DATABASE_PASSWORD=SENHA_FORTE_MARIADB_AQUI_GERE_COM_openssl rand -hex 24

# Variáveis para o container MariaDB
MYSQL_ROOT_PASSWORD=SENHA_ROOT_MARIADB_AQUI
MYSQL_DATABASE=espocrm
MYSQL_USER=espocrm
MYSQL_PASSWORD=SENHA_FORTE_MARIADB_AQUI_GERE_COM_openssl rand -hex 24

# -----------------------------------------------------------------------------
# ADMINISTRADOR INICIAL
# -----------------------------------------------------------------------------
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=SENHA_FORTE_ADMIN_AQUI_GERE_COM_openssl rand -base64 24

# -----------------------------------------------------------------------------
# URL E SSL
# -----------------------------------------------------------------------------
#ESPOCRM_SITE_URL=https://crm.seudominio.com

# -----------------------------------------------------------------------------
# EMAIL / SMTP (Mailtrap para ambiente de teste)
# -----------------------------------------------------------------------------
ESPOCRM_SMTP_SERVER=smtp.mailtrap.io
ESPOCRM_SMTP_PORT=587
ESPOCRM_SMTP_AUTH=true
ESPOCRM_SMTP_SECURITY=TLS
ESPOCRM_SMTP_USERNAME=SEU_MAILTRAP_USERNAME
ESPOCRM_SMTP_PASSWORD=SEU_MAILTRAP_PASSWORD
ESPOCRM_SMTP_FROM_ADDRESS=noreply@seudominio.com
ESPOCRM_SMTP_FROM_NAME=EspoCRM

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
ESPOCRM_LANGUAGE=pt_BR
TZ=America/Fortaleza

