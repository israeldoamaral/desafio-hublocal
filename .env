# S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# EMAIL / SMTP
# -----------------------------------------------------------------------------
MAILER_SENDER_EMAIL=noreply@seudominio.com
SMTP_DOMAIN=seudominio.com
SMTP_ADDRESS=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=SEU_MAILTRAP_USERNAME
SMTP_PASSWORD=SEU_MAILTRAP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=pt_BR
ENABLE_ACCOUNT_SIGNUP=false
LOG_LEVEL=info
LOG_SIZE=500

# -----------------------------------------------------------------------------
# 2FA (Two-Factor Authentication)
# -----------------------------------------------------------------------------
# Habilitado por padrão nas configurações de conta do Chatwoot


