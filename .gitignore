# =============================================================================
# .gitignore - Stack Traefik + Chatwoot + EspoCRM
# =============================================================================

# -----------------------------------------------------------------------------
# ARQUIVOS DE AMBIENTE (NUNCA commitar!)
# -----------------------------------------------------------------------------
.env
*.env
!.env.exemplo

# Certificados e chaves
*.pem
*.key
*.crt
*.csr
letsencrypt/
traefik/letsencrypt/

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/
/var/log/

# -----------------------------------------------------------------------------
# BACKUPS
# -----------------------------------------------------------------------------
backups/
*.sql.gz
*.tar.gz
*.bak
*.dump

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# SISTEMA OPERACIONAL
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# EDITORES
# -----------------------------------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# -----------------------------------------------------------------------------
# TEMPORÁRIOS
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
